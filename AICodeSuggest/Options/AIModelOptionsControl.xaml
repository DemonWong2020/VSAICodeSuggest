<UserControl x:Class="AICodeSuggest.Options.AIModelOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="520">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="AI 模型配置"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Provider 类型 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Provider 类型"
                   VerticalAlignment="Center" Margin="0,0,10,8"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  x:Name="ProviderTypeCombo"
                  SelectedIndex="0"
                  SelectionChanged="OnProviderTypeChanged"
                  VerticalAlignment="Center" Margin="0,0,0,8"
                  IsEditable="False">
            <ComboBoxItem Content="OpenAI兼容"/>
            <ComboBoxItem Content="Ollama 本地"/>
            <ComboBoxItem Content="自定义"/>
        </ComboBox>

        <!-- API 地址 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="API 地址"
                   VerticalAlignment="Center" Margin="0,0,10,8"/>
        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                 Text="{Binding ApiEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center" Margin="0,0,0,8"
                 Height="24"/>

        <!-- API Key -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="API Key"
                   VerticalAlignment="Center" Margin="0,0,10,8"/>
        <PasswordBox Grid.Row="3" Grid.Column="1"
                     x:Name="ApiKeyPasswordBox"
                     PasswordChanged="OnApiKeyPasswordChanged"
                     VerticalAlignment="Center" Margin="0,0,4,8"
                     Height="24"/>
        <Button Grid.Row="3" Grid.Column="2"
                x:Name="TestConnectionButton"
                Content="测试连接"
                Height="24" Width="100"
                Margin="0,0,0,8"
                Click="OnTestConnectionClick"/>

        <!-- 连接测试结果 -->
        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                   x:Name="ConnectionStatusText"
                   Text=""
                   Margin="0,0,0,8"
                   FontWeight="Bold"/>

        <!-- 模型名称 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="模型名称"
                   VerticalAlignment="Center" Margin="0,0,10,8"/>
        <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                 Text="{Binding ModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center" Margin="0,0,0,8"
                 Height="24"/>

        <!-- Temperature -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Temperature"
                   VerticalAlignment="Center" Margin="0,0,10,8"/>
        <Slider Grid.Row="6" Grid.Column="1"
                Minimum="0" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                Value="{Binding Temperature, Mode=TwoWay}"
                VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBlock Grid.Row="6" Grid.Column="2"
                   Text="{Binding Temperature, StringFormat={}{0:F1}}"
                   VerticalAlignment="Center" Margin="0,0,0,8"/>

        <!-- Top P -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Top P"
                   VerticalAlignment="Center" Margin="0,0,10,8"/>
        <Slider Grid.Row="7" Grid.Column="1"
                Minimum="0" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                Value="{Binding TopP, Mode=TwoWay}"
                VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBlock Grid.Row="7" Grid.Column="2"
                   Text="{Binding TopP, StringFormat={}{0:F2}}"
                   VerticalAlignment="Center" Margin="0,0,0,8"/>

        <!-- Provider 切换说明 -->
        <TextBlock Grid.Row="8" Grid.ColumnSpan="3"
                   Margin="0,16,0,0" FontWeight="SemiBold"
                   Text="Provider 说明："/>
        <TextBlock Grid.Row="9" Grid.ColumnSpan="3"
                   Margin="0,4,0,12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Text="• OpenAI兼容：适用于 OpenAI API 及所有兼容 OpenAI Chat Completions 格式的服务（vLLM、LM Studio、DeepSeek 等）&#x0a;• Ollama 本地：适用于本地运行的 Ollama 服务，默认地址 http://localhost:11434&#x0a;• 自定义：使用自定义的 API 地址和认证方式"/>

        <!-- 底部说明 -->
        <TextBlock Grid.Row="10" Grid.ColumnSpan="3"
                   Text="API Key 使用 Windows DPAPI 加密存储，仅当前用户可解密。"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   FontStyle="Italic" Margin="0,4,0,0"/>
    </Grid>
</UserControl>
