<UserControl x:Class="AICodeSuggest.Options.GeneralOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="520">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="通用设置"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- ──── 触发设置分组 ──── -->
        <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="触发设置"
                   FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- 启用建议 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="启用内联建议"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <CheckBox Grid.Row="2" Grid.Column="1"
                  IsChecked="{Binding EnableSuggestions, Mode=TwoWay}"
                  VerticalAlignment="Center" Margin="0,0,0,6"/>

        <!-- 触发延迟 -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="触发延迟(毫秒)"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <Slider Grid.Row="3" Grid.Column="1"
                Minimum="100" Maximum="1000" TickFrequency="50" IsSnapToTickEnabled="True"
                Value="{Binding TriggerDelayMs, Mode=TwoWay}"
                VerticalAlignment="Center" Margin="0,0,8,6"/>
        <TextBlock Grid.Row="3" Grid.Column="2"
                   Text="{Binding TriggerDelayMs, StringFormat={}{0} ms}"
                   VerticalAlignment="Center" Margin="0,0,0,6"/>

        <!-- ──── 上下文分组 ──── -->
        <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="上下文引擎"
                   FontWeight="SemiBold" Margin="0,10,0,6"/>

        <!-- 智能结构检测 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="智能结构检测"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <CheckBox Grid.Row="5" Grid.Column="1"
                  IsChecked="{Binding EnableSmartContext, Mode=TwoWay}"
                  VerticalAlignment="Center" Margin="0,0,0,6"/>

        <!-- 上下文行数（光标前） -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="光标前上下文行数"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <Grid Grid.Row="6" Grid.Column="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Width="200"
                    Minimum="5" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True"
                    Value="{Binding ContextLinesBefore, Mode=TwoWay}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding ContextLinesBefore, StringFormat={}{0} 行}"
                       VerticalAlignment="Center"/>
        </Grid>
        <TextBlock Grid.Row="6" Grid.Column="2"/>

        <!-- 上下文行数（光标后） -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="光标后上下文行数"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <Grid Grid.Row="7" Grid.Column="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Width="200"
                    Minimum="0" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding MaxLinesAfter, Mode=TwoWay}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding MaxLinesAfter, StringFormat={}{0} 行}"
                       VerticalAlignment="Center"/>
        </Grid>
        <TextBlock Grid.Row="7" Grid.Column="2"/>

        <!-- 最大上下文Token -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="最大上下文 Token 数"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <Grid Grid.Row="8" Grid.Column="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Width="200"
                    Minimum="0" Maximum="8192" TickFrequency="512" IsSnapToTickEnabled="True"
                    Value="{Binding MaxContextTokens, Mode=TwoWay}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding MaxContextTokens, StringFormat={}{0} tokens}"
                       VerticalAlignment="Center"/>
        </Grid>
        <TextBlock Grid.Row="8" Grid.Column="2"/>

        <!-- ──── 建议分组 ──── -->
        <TextBlock Grid.Row="9" Grid.ColumnSpan="3" Text="建议输出"
                   FontWeight="SemiBold" Margin="0,10,0,6"/>

        <!-- 建议最大长度 -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="建议最大长度(字符数)"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <Grid Grid.Row="10" Grid.Column="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Width="200"
                    Minimum="50" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True"
                    Value="{Binding SuggestionMaxLength, Mode=TwoWay}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding SuggestionMaxLength, StringFormat={}{0} 字符}"
                       VerticalAlignment="Center"/>
        </Grid>
        <TextBlock Grid.Row="10" Grid.Column="2"/>

        <!-- ──── 多行显示分组 ──── -->
        <TextBlock Grid.Row="11" Grid.ColumnSpan="3" Text="多行显示"
                   FontWeight="SemiBold" Margin="0,10,0,6"/>

        <!-- 最大显示行数 -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="最大显示行数"
                   VerticalAlignment="Center" Margin="0,0,10,6"/>
        <Grid Grid.Row="12" Grid.Column="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" Width="200"
                    Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding MaxSuggestionDisplayLines, Mode=TwoWay}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding MaxSuggestionDisplayLines, StringFormat={}{0} 行}"
                       VerticalAlignment="Center"/>
        </Grid>
        <TextBlock Grid.Row="12" Grid.Column="2"/>
    </Grid>
</UserControl>
